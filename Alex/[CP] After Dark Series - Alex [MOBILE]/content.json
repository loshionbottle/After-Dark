{
    "Format": "2.8.0",
    /*-------------------------------------------------------------------------------------------------------------------------------------------------------------------------
       ████  ███  █   █ █████ █████  ████ 
      █     █   █ ██  █ █       █   █     
      █     █   █ █ █ █ ████    █   █  ██ 
      █     █   █ █  ██ █       █   █   █ 
       ████  ███  █   █ █     █████  ███  
    ------------------------------------------------------------------------------------------------------------------------------------------------------------------------- */
    "ConfigSchema": {
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    PRONOUNS 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        "Default Player Pronouns": {
            "AllowValues": "Neutral, Feminine, Masculine",
            "Default": "Neutral",
            "Section": "Pronouns",
            "Description": "English is weird and I can't accomplish all grammar rules with all the different pronoun options. There are especially a few lines where it's like... themself vs. themselves and rather than having you guys put in 40 different customizations, certain lines will default to whatever you choose here. I tried my best to accomodate your pronouns otherwise!!"
        },
        "Player Pronouns 1": {
            "Default": "Them",
            "AllowValues": "Them, Her, Him",
            "Section": "Pronouns",
            "Description": "Sets the player's desired pronoun."
        },
        "Player Pronouns 2": {
            "Default": "Their",
            "AllowValues": "Their, Her, His",
            "Section": "Pronouns",
            "Description": "Sets the player's desired pronoun."
        },
        "Player Pronouns 3": {
            "Default": "They",
            "AllowValues": "They, She, He",
            "Section": "Pronouns",
            "Description": "Sets the player's desired pronoun."
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    PLAYER ENDEARMENT 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        "Pet Name": {
            "Default": "Babe",
            "AllowValues": "Babe, Baby, Babygirl, Babyboy, Darling, Princess, Prince, Flower, Love, My Love, Angel, Doll, Dollface, Sweetheart, Honey, Sunshine, Bunny, Kitty, Kitten",
            "Section": "Endearment",
            "Description": "Sets the player's desired pet name."
        },
        "Descriptive Word": {
            "Default": "Cute",
            "AllowValues": "Cute, Pretty, Handsome, Sweet, Lovely, Sexy, Adorable, Gorgeous",
            "Section": "Endearment",
            "Description": "Sets the player's desired descriptive word."
        },
        "Good...": {
            "Default": "Farmer",
            "AllowValues": "Farmer, Girl, Boy, Whore, Pet, Kitten, Kitty, Thing",
            "Section": "Endearment",
            "Description": "Sets the player's desired good... name. Works like \"Good Girl\", etc."
        },
        "Marriage Affection": {
            "Default": "Spouse",
            "AllowValues": "Husband, Wife, Spouse, Shawty Bae",
            "Section": "Endearment",
            "Description": "Sets the player's desired name after marriage."
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    DIALOGUE 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        // Whether to include each dialogue file
        "After Dark Dialogue": {
            "AllowValues": "All Dialogue, No Jealousy Dialogue, No Dialogue",
            "Default": "All Dialogue",
            "Section": "Dialogue",
            "Description": "Toggle between which dialogue you'd like this pack to add. Choosing \"No Jealousy Dialogue\" will disable all jealousy-related dialogue this pack offers. If you'd like to turn off all dialogue, select \"No Dialogue\"."
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    EVENTS 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        // Whether to include the events as a whole or not
        "After Dark Events": {
            "AllowValues": "All Events, No Events",
            "Default": "All Events",
            "Section": "Events",
            "Description": "Toggle between which events you'd like this pack to add. Choosing \"All Events\" will include ALL events his pack offers. If you'd like to turn off all events, select \"No Events\"."
        },
        "Choking Events": {
            "AllowValues": "I'm ok with choking, I'm not ok with choking",
            "Default": "I'm not ok with choking",
            "Section": "Events",
            "Description": "Toggle between which events you'd like this pack to add. Choosing \"I'm ok with choking\" will include ALL, non-edited events his pack offers. If you'd like to not be choked whatsoever, select \"I'm not ok with choking\"."
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    MAIL 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        // Whether to include jealousy mail as a whole or not
        "After Dark Mail": {
            "AllowValues": "Mail, No Mail",
            "Default": "Mail",
            "Section": "Mail",
            "Description": "Toggle between which mail you'd like this pack to add. Choosing \"Mail\" will include ALL mail he (or the figure) sends. If you'd like to turn off all mail, select \"No Mail\"."
        }
    },
    /*-------------------------------------------------------------------------------------------------------------------------------------------------------------------------
     █████  ███  █  █  █████ █   █ █████ 
       █   █   █ █ █   █     ██  █ █     
       █   █   █ ██ █  ████  █ █ █ █████ 
       █   █   █ █  █  █     █  ██     █ 
       █    ███  █   █ █████ █   █ █████
    ------------------------------------------------------------------------------------------------------------------------------------------------------------------------- */
    "DynamicTokens": [
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    PRONOUNS 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        {
            "Name": "GeneralPlayerPronoun",
            "Value": "|PPN1={{Random: {{Player Pronouns 1}} |key=PlayerPronouns}} |LPPN1={{Random: {{Lowercase: {{Player Pronouns 1}}}} |key=PlayerPronouns}} |PPN2={{Random: {{Player Pronouns 2}} |key=PlayerPronouns}} |LPPN2={{Random: {{Lowercase: {{Player Pronouns 2}}}} |key=PlayerPronouns}} |PPN3={{Random: {{Player Pronouns 3}} |key=PlayerPronouns}} |LPPN3={{Random: {{Lowercase: {{Player Pronouns 3}}}} |key=PlayerPronouns}}"
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    PLAYER ENDEARMENT 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        {
            "Name": "GeneralPlayerEndearment",
            "Value": "|PetName={{Random: {{Pet Name}} |key=PlayerEndearment}} |LPetName={{Random: {{Lowercase: {{Pet Name}}}} |key=PlayerEndearment}} |Descript={{Random: {{Descriptive Word}} |key=PlayerEndearment}} |LDescript={{Random: {{Lowercase: {{Descriptive Word}}}} |key=PlayerEndearment}} |GoodName={{Random: {{Good...}} |key=PlayerEndearment}} |LGoodName={{Random: {{Lowercase: {{Good...}}}} |key=PlayerEndearment}} |MarriageName={{Random:{{Marriage Affection}} |key=PlayerEndearment}} |LMarriageName={{Random: {{Lowercase: {{Marriage Affection}}}} |key=PlayerEndearment}}"
        },
        /*---------------------------------------------------------------------------------------------------------------------------------------------------------------------
        |    MISC 
        ----------------------------------------------------------------------------------------------------------------------------------------------------------------------*/
        {
            "Name": "WeekDayList",
            "Value": "Sun, Mon, Tue, Wed, Thu, Fri, Sat"
        },
        {
            "Name": "WeekDay",
            "Value": "{{WeekDayList |valueAt={{Query: {{Day}}%7}}}}"
        },
        {
            "Name": "FarmerHarvest",
            "Value": "animate farmer true false 200 58 59 60 61 6"
        },
        {
            "Name": "GrannyHarvest",
            "Value": "animate Evelyn false false 250 17 18 18 18 17 17 18 18 17"
        },
        {
            "Name": "FarmerAlmostPassOut",
            "Value": "animate farmer false false 500 16 0 16 0"
        },
        {
            "Name": "FarmerPassOut",
            "Value": "animate farmer false false 500 16 0 16 4 5"
        }
    ],
    /*-------------------------------------------------------------------------------------------------------------------------------------------------------------------------
